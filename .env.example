# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=realtime
MYSQL_USER=root
MYSQL_PASSWORD=changeme

# Firebase
FIREBASE_KEY_PATH=src/main/resources/firebase-key.json

# Admin (generate a strong token for production)
ADMIN_TOKEN=changeme

# OpenAI (required for voice proxy)
OPENAI_API_KEY=sk-...

# Storage
STORAGE_PATH=./storage/

# CORS (comma-separated origins)
CORS_ORIGINS=https://yourdomain.com

# DDL (never use 'update' in production)
DDL_AUTO=validate
